{
  "name": "CRX Blueprint",
  "version": "1.0",
  "manifest_version": 3,
  "description": "Seamlessly extract Extension packages to ZIP/CRX.",
  "author": "Vaishnav Raj",
  "permissions": [
    "downloads",
    "contextMenus",
    "activeTab"
  ],
  "background": {
    "service_worker": "background/background.js"
  },
  "host_permissions": [
    "<all_urls>"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": "icons/icon128.png",
    "default_popup": "popup/popup.html"
  }
}